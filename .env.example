# ---- Copy to .env and adjust ----

# MongoDB
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=changeme
MONGO_DATABASE=hackhtml

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=documents

# Backend
# Base64 / long random string used to sign JWTs. CHANGE in production.
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-bytes-long
JWT_EXPIRATION_MS=86400000
# Where the frontend lives (used for CORS + OAuth2 redirect back)
FRONTEND_URL=http://localhost:3000

# OAuth2 providers (leave blank to disable a provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Frontend -> backend API base URL (browser-facing)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
